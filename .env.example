# ===========================
# apps/web 環境變數
# ===========================

# PostgreSQL（Supabase）- runtime 查詢用 pooled connection
DATABASE_URL="postgresql://user:password@host:6543/dbname?pgbouncer=true"
# PostgreSQL（Supabase）- migration 用 direct connection
DIRECT_URL="postgresql://user:password@host:5432/dbname"

# JWT
JWT_SECRET="your-jwt-secret-at-least-32-chars"

# OpenAI
OPENAI_API_KEY="sk-..."
OPENAI_MODEL="gpt-4o-mini"

# Cloudflare R2（S3 compatible）
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="remote-care-files"

# Upstash Redis（Rate Limiting）
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Device API
DEVICE_API_TOKEN="dev-device-token-12345"

# Cron Secret
CRON_SECRET="your-cron-secret"

# AI Debug Logging（production 必須設為 false）
AI_DEBUG_LOGGING="true"

# Sentry
SENTRY_DSN=""

# App URL
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ===========================
# apps/mobile 環境變數
# ===========================

# API URL
EXPO_PUBLIC_API_URL="http://localhost:3000"

# Sentry
EXPO_PUBLIC_SENTRY_DSN=""
